# Copy to .env and adjust. The API reads these from the environment.
ADDR=:8080
DATABASE_URL=postgres://blazeaid:blazeaid@localhost:5432/blazeaid?sslmode=disable
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=dev-insecure-secret-change-me
# Comma-separated allowed CORS origins for browser clients (use specific origins in prod).
CORS_ORIGINS=*
# Per-IP rate limit (requests/minute; 0 disables) and max request body size in bytes.
RATE_LIMIT_RPM=100
MAX_BODY_BYTES=1048576
